image: map.pgm        # 对应的图像文件名
mode: trinary         # 地图模式：三进制（只有占用、空闲、未知）
resolution: 0.050000  # 分辨率：每个像素代表 0.05 米 (5cm)
origin: [-10.0, -10.0, 0.0]  # 地图左下角的坐标 [x, y, yaw]
negate: 0             # 是否反转颜色（0 表示白色为自由空间）
occupied_thresh: 0.65 # 占用阈值：高于此值视为障碍物
free_thresh: 0.196    # 空闲阈值：低于此值视为可行走区域